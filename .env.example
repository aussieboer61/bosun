# Copy this file to .env and fill in your values

# Docker group GID on the host — find it with: getent group docker | cut -d: -f3
DOCKER_GID=999

# Where Bosun stores its data (configs, compose files, user accounts, logs)
BOSUN_DATA_DIR=./data

# Port to expose Bosun on
BOSUN_PORT=4080

# Timezone (e.g. America/New_York, Europe/London, Asia/Tokyo)
TZ=UTC

# JWT signing secret — CHANGE THIS to a long random string
# Generate one with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_random_secret
